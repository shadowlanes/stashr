# ── Required: add your Clerk keys ──────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Pre-configured for local Docker (no changes needed) ────────────────────
PORT=4101
DATABASE_URL=postgres://stashr:stashr@postgres:5432/stashr

# MinIO (local S3-compatible storage — swap for real R2 in production)
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=stashr
R2_SECRET_ACCESS_KEY=stashr123
R2_BUCKET_NAME=stashr-articles
R2_ENDPOINT=http://minio:9000

# ── Production (Cloudflare R2) — uncomment and fill when deploying ─────────
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=stashr-articles
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ── Host-side DB URL (for running migrations from host, not inside Docker) ──
# DATABASE_URL=postgres://stashr:stashr@localhost:4102/stashr
